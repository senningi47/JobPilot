# ===== Database =====
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=jobpilot
MYSQL_USER=root
MYSQL_PASSWORD=your_password

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Qdrant (Vector DB) =====
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ===== RabbitMQ =====
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ===== AI / LLM =====
ANTHROPIC_API_KEY=your_anthropic_api_key
LLM_MODEL_STRONG=claude-opus-4-7
LLM_MODEL_MEDIUM=claude-sonnet-4-6
LLM_MODEL_LIGHT=claude-haiku-4-5-20251001

# ===== File Storage =====
OSS_ENDPOINT=localhost:9000
OSS_ACCESS_KEY=minioadmin
OSS_SECRET_KEY=minioadmin
OSS_BUCKET=jobpilot

# ===== JWT =====
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRATION=86400

# ===== Application =====
APP_ENV=development
APP_PORT_FRONTEND=3000
APP_PORT_BACKEND=8080
APP_PORT_AI_SERVICE=8000
